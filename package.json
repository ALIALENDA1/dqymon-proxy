{
  "name": "growtopia-proxy",
  "version": "1.0.0",
  "description": "Growtopia Proxy with custom commands",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build": "pkg . --targets node18-win-x64 --output dist/dqymon-proxy.exe",
    "build:diagnose": "pkg diagnose.js --targets node18-win-x64 --output dist/dqymon-diagnose.exe",
    "build:all": "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --out-path dist"
  },
  "pkg": {
    "assets": [
      "config/**/*"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "growtopia",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2",
    "nodemon": "^3.1.14"
  }
}
